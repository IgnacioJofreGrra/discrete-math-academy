        "exercises": [
          {
            "id": "exercise_init_0_14_1",
            "type": "challenge",
            "title": "Chequeo rapido de factorizacion",
            "problem": "Cual es la factorizacion correcta de x^3-27?",
            "options": [
              {
                "value": "(x-3)(x^2+3x+9)",
                "correct": true,
                "explanation": "Correcto. Es diferencia de cubos: a^3-b^3=(a-b)(a^2+ab+b^2)."
              },
              {
                "value": "(x-3)^3",
                "correct": false,
                "explanation": "Incorrecto. Al expandir no se obtiene x^3-27."
              },
              {
                "value": "(x+3)(x^2-3x+9)",
                "correct": false,
                "explanation": "Esa corresponde a x^3+27, no a x^3-27."
              }
            ],
            "difficulty": "easy"
          },
          {
            "id": "exercise_init_0_14_2",
            "type": "step_by_step",
            "title": "Expresar en un unico logaritmo",
            "steps": [
              {
                "instruction": "Parte de log_6(x)+4log_6(y)-log_6(z). Convierte el coeficiente 4.",
                "hint": "k log_a(t)=log_a(t^k)",
                "answer": "log_6(x)+log_6(y^4)-log_6(z)"
              },
              {
                "instruction": "Combina suma de logaritmos.",
                "hint": "log_a(u)+log_a(v)=log_a(uv)",
                "answer": "log_6(x*y^4)-log_6(z)"
              },
              {
                "instruction": "Combina resta de logaritmos para obtener uno solo.",
                "hint": "log_a(u)-log_a(v)=log_a(u/v)",
                "answer": "log_6((x*y^4)/z)"
              }
            ],
            "difficulty": "medium"
          }
        ]
