{
  "id": "module_init_2_practica_cientifica",
  "title": "Matematica Inicial 2: Practica Integrada y Notacion Cientifica",
  "description": "Repaso guiado con practicos resueltos y notacion cientifica.",
  "order": 2,
  "track": "initial",
  "difficulty": "intermediate",
  "estimatedHours": 10,
  "icon": "book-open",
  "sections": [
    {
      "id": "section_init_0_12",
      "title": "Practica integrada 2.3.1",
      "description": "Conjunto de ejercicios mixtos sobre operaciones combinadas, simplificacion, radicales, potencias y logaritmos.",
      "order": 12,
      "content": {
        "theory": {
          "definition": "En esta practica se integran todas las tecnicas de la seccion: jerarquia de operaciones, reglas de potencia y radicacion, racionalizacion y propiedades de logaritmos.",
          "instructions": [
            "Asumir letras como numeros positivos, salvo aclaracion.",
            "Justificar cada paso indicando propiedad usada.",
            "Distinguir operaciones validas de errores frecuentes.",
            "Comparar expresiones con y sin parentesis en bases negativas."
          ],
          "example_categories": [
            "Operaciones combinadas con potencias, raices y logaritmos",
            "Simplificacion algebraica con exponentes racionales",
            "Racionalizacion de denominadores",
            "Reescritura a un unico logaritmo",
            "Deteccion de razonamientos incorrectos"
          ],
          "warnings": [
            "No usar distributiva de potencia o logaritmo sobre suma/resta.",
            "No omitir parentesis en bases negativas: (-2)^4 no es igual a -2^4.",
            "Verificar siempre dominio de radicales y logaritmos antes de operar."
          ]
        },
        "para_que_sirve": {
          "title": "Para que sirve",
          "applications": [
            {
              "area": "Preparacion de evaluaciones",
              "description": "Consolida tecnicas en un formato de entrenamiento acumulativo.",
              "example": "Resuelve una combinada que involucra logaritmos, raices y potencias en una sola cadena."
            },
            {
              "area": "Diagnostico de errores",
              "description": "Ayuda a identificar fallas recurrentes de procedimiento antes de avanzar de capitulo.",
              "example": "Detectar por que una expansion aparentemente correcta lleva a una contradiccion."
            }
          ]
        },
        "exercises": [
          {
            "id": "exercise_init_0_12_1",
            "type": "challenge",
            "title": "Error frecuente",
            "problem": "Que afirmacion es incorrecta en general?",
            "options": [
              {
                "value": "(x+y)^2 = x^2 + y^2",
                "correct": true,
                "explanation": "Incorrecta en general; falta el termino 2xy."
              },
              {
                "value": "a^m * a^n = a^(m+n)",
                "correct": false,
                "explanation": "Correcta para misma base."
              },
              {
                "value": "log_a(xy)=log_a(x)+log_a(y)",
                "correct": false,
                "explanation": "Correcta para x,y>0 y a>0,a!=1."
              }
            ],
            "difficulty": "medium"
          },
          {
            "id": "exercise_init_0_12_2",
            "type": "step_by_step",
            "title": "Comparar con y sin parentesis",
            "steps": [
              {
                "instruction": "Calcula (-2)^4.",
                "hint": "Base negativa con exponente par.",
                "answer": "16"
              },
              {
                "instruction": "Calcula -2^4.",
                "hint": "Primero potencia de 2, luego signo menos.",
                "answer": "-16"
              },
              {
                "instruction": "Explica la diferencia.",
                "hint": "Los parentesis cambian la base que se eleva.",
                "answer": "En (-2)^4 la base completa es -2; en -2^4 solo se eleva 2 y luego se aplica el signo menos."
              }
            ],
            "difficulty": "easy"
          }
        ]
      }
    },
    {
      "id": "section_init_0_13",
      "title": "Notacion cientifica (2.3.2)",
      "description": "Introduce la forma m*10^n para escribir numeros muy grandes o muy pequenos.",
      "order": 13,
      "content": {
        "theory": {
          "definition": "Un numero positivo x esta en notacion cientifica si se escribe como m*10^n, con n entero y 1<=m<10. El exponente n indica el orden de magnitud.",
          "examples": [
            {
              "text": "Potencias de diez basicas.",
              "latex": "10^5=100000,\\ 10^{-4}=0.0001"
            },
            {
              "text": "Mover el punto decimal al multiplicar por potencias de diez.",
              "latex": "2.5*10^7=25000000,\\ 2.5*10^{-4}=0.00025"
            },
            {
              "text": "Forma estandar con mantisa entre 1 y 10.",
              "latex": "74000000000000=7.4*10^{13}"
            }
          ],
          "notes": [
            "Si n>0, el punto se desplaza n lugares a la derecha.",
            "Si n<0, el punto se desplaza |n| lugares a la izquierda.",
            "La notacion cientifica facilita comparaciones por orden de magnitud."
          ]
        },
        "para_que_sirve": {
          "title": "Para que sirve",
          "applications": [
            {
              "area": "Ciencias naturales",
              "description": "Expresa magnitudes astronomicas o microscopicas de forma compacta.",
              "example": "Distancias espaciales y masas atomicas suelen escribirse con 10^n."
            },
            {
              "area": "Computacion y datos",
              "description": "Permite leer y comparar facilmente escalas de datos muy dispares.",
              "example": "Latencias, frecuencias y tamaños pueden diferir en varios ordenes de magnitud."
            }
          ]
        },
        "exercises": [
          {
            "id": "exercise_init_0_13_1",
            "type": "challenge",
            "title": "Forma cientifica correcta",
            "problem": "Cual esta correctamente escrita en notacion cientifica?",
            "options": [
              {
                "value": "0.74*10^14",
                "correct": false,
                "explanation": "Incorrecto: la mantisa debe estar entre 1 y 10."
              },
              {
                "value": "7.4*10^13",
                "correct": true,
                "explanation": "Correcto: 1<=7.4<10."
              },
              {
                "value": "74*10^12",
                "correct": false,
                "explanation": "Incorrecto: mantisa mayor que 10."
              }
            ],
            "difficulty": "easy"
          },
          {
            "id": "exercise_init_0_13_2",
            "type": "step_by_step",
            "title": "Convertir a notacion cientifica",
            "steps": [
              {
                "instruction": "Escribe 150000000 en forma m*10^n.",
                "hint": "Mueve el punto hasta obtener mantisa entre 1 y 10.",
                "answer": "1.5*10^8"
              },
              {
                "instruction": "Escribe 0.0000016726 en notacion cientifica.",
                "hint": "Cuenta desplazamientos hacia la derecha para la mantisa.",
                "answer": "1.6726*10^-6"
              },
              {
                "instruction": "Indica el orden de magnitud del segundo numero.",
                "hint": "Es el exponente de 10.",
                "answer": "-6"
              }
            ],
            "difficulty": "medium"
          }
        ]
      }
    },
